generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  documents Document[]
}

model Document {
  id             String        @id @default(cuid())
  type           String
  reference      String        @unique
  data           Json
  createdAt      DateTime      @default(now())
  authorId       String?
  destinataireId String?
  expediteurId   String?
  author         User?         @relation(fields: [authorId], references: [id])
  destinataire   Destinataire? @relation(fields: [destinataireId], references: [id])
  expediteur     Expediteur?   @relation(fields: [expediteurId], references: [id])
}

model Destinataire {
  id           String     @id @default(cuid())
  nom          String     @unique
  raison       String?
  informations String?
  adresse      String?
  documents    Document[]
}

model Expediteur {
  id        String     @id @default(cuid())
  nom       String     @unique
  transport String?
  raison    String?
  adresse   String?
  contact   String?
  documents Document[]
}

model Template {
  id          Int      @id
  nom         String
  description String?
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
}
