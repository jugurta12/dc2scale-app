generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  documents Document[]
}

model Document {
  id             String        @id @default(cuid())
  type           String
  reference      String        @unique
  data           Json
  createdAt      DateTime      @default(now())
  authorId       String?
  destinataireId String?
  expediteurId   String?
  clientId       String?
  author         User?         @relation(fields: [authorId], references: [id])
  destinataire   Destinataire? @relation(fields: [destinataireId], references: [id])
  expediteur     Expediteur?   @relation(fields: [expediteurId], references: [id])
  client         Client?       @relation(fields: [clientId], references: [id])
  items      QuoteItem[]?
  authorId   String?
}

model Destinataire {
  id           String     @id @default(cuid())
  nom          String     @unique
  raison       String?
  informations String?
  adresse      String?
  documents    Document[]
}

model Expediteur {
  id        String     @id @default(cuid())
  nom       String     @unique
  transport String?
  raison    String?
  adresse   String?
  contact   String?
  documents Document[]
}

model Client {
  id                   String     @id @default(cuid())
  nom                  String     @unique
  adresse              String?
  numeroImmatriculation String?
  createdAt            DateTime   @default(now())
  documents            Document[]
}

model Template {
  id          Int      @id
  nom         String
  description String?
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
}


model QuoteItem {
  id          String   @id @default(cuid())
  description String   // Nom du produit
  details     String?  // Description longue
  quantity    Float    @default(1)
  unitPrice   Float    // Prix unitaire HT
  tvaRate     Float    @default(20) // Taux TVA (ex: 20)
  isRecurring Boolean  @default(true) // true = MRC, false = NRC
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}